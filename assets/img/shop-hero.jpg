ll"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼm">loadJSON</span><span>(</span><span class="ͼk">"content/services.json"</span><span>)</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="2022" data-end="2052">(or <code data-start="2026" data-end="2051">./content/services.json</code>)</p>
