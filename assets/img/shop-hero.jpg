v id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>[</span><br><span>  {</span><br><span>    "title": </span><span class="ͼk">"Collision Repair (MPI)"</span><span>,</span><br><span>    "description": </span><span class="ͼk">"MPI accredited collision repairs restoring vehicles to manufacturer standards after accidents or damage."</span><br><span>  },</span><br><span>  {</span><br><span>    "title": </span><span class="ͼk">"Autobody Repair"</span><span>,</span><br><span>    "description": </span><span class="ͼk">"Professional dent repair, panel replacement, and structural body repairs."</span><br><span>  },</span><br><span>  {</span><br><span>    "title": </span><span class="ͼk">"Frame Straightening"</span><span>,</span><br><span>    "description": </span><span class="ͼk">"Precision frame and structural alignment using professional frame straightening equipment."</span><br><span>  },</span><br><span>  {</span><br><span>    "title": </span><span class="ͼk">"Paint &amp; Refinishing"</span><span>,</span><br><span>    "description": </span><span class="ͼk">"High-quality paint matching and refinishing for seamless factory-quality results."</span><br><span>  },</span><br><span>  {</span><br><span>    "title": </span><span class="ͼk">"Mechanical Repair"</span><span>,</span><br><span>    "description": </span><span class="ͼk">"Diagnostics and mechanical repairs including engine, suspension, and general vehicle maintenance."</span><br><span>  },</span><br><span>  {</span><br><span>    "title": </span><span class="ͼk">"Auto Glass Replacement"</span><span>,</span><br><span>    "description": </span><span class="ͼk">"Windshield and automotive glass replacement with proper sealing and installation."</span><br><span>  },</span><br><span>  {</span><br><span>    "title": </span><span class="ͼk">"Diagnostics &amp; ADAS Scanning"</span><span>,</span><br><span>    "description": </span><span class="ͼk">"Pre-scan and post-scan diagnostics including ADAS system calibration after repairs."</span><br><span>  }</span><br><span>]</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="1317" data-end="1322">Then:</p>
