)</span><span class="ͼg">.</span><span>join(</span><span class="ͼk">""</span><span>);</span><br><span>}</span><br><br><span>(</span><span class="ͼg">async</span><span> </span><span class="ͼg">function</span><span> </span><span class="ͼm">init</span><span>() {</span><br><span>  </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"year"</span><span>)</span><span class="ͼg">.</span><span>textContent </span><span class="ͼg">=</span><span> </span><span class="ͼg">new</span><span> </span><span class="ͼm">Date</span><span>()</span><span class="ͼg">.</span><span>getFullYear();</span><br><br><span>  </span><span class="ͼg">const</span><span> </span><span class="ͼm">settings</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼg">await</span><span> </span><span class="ͼm">loadJSON</span><span>(</span><span class="ͼk">"/content/settings.json"</span><span>);</span><br><span>  </span><span class="ͼg">const</span><span> </span><span class="ͼm">services</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼg">await</span><span> </span><span class="ͼm">loadJSON</span><span>(</span><span class="ͼk">"/content/services.json"</span><span>);</span><br><br><span>  </span><span class="ͼg">const</span><span> </span><span class="ͼm">phoneHref</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼk">`tel:</span><span>${</span><span class="ͼm">settings</span><span class="ͼg">.</span><span>phone</span><span class="ͼg">.</span><span>replace(</span><span class="ͼk">/[^\d+]/g</span><span>, </span><span class="ͼk">""</span><span>)}</span><span class="ͼk">`</span><span>;</span><br><span>  </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"callBtn"</span><span>)</span><span class="ͼg">.</span><span>href </span><span class="ͼg">=</span><span> </span><span class="ͼm">phoneHref</span><span>;</span><br><span>  </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"ctaCall"</span><span>)</span><span class="ͼg">.</span><span>href </span><span class="ͼg">=</span><span> </span><span class="ͼm">phoneHref</span><span>;</span><br><br><span>  </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"ctaDirections"</span><span>)</span><span class="ͼg">.</span><span>href </span><span class="ͼg">=</span><span> </span><span class="ͼm">settings</span><span class="ͼg">.</span><span>mapsUrl;</span><br><span>  </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"metaLine"</span><span>)</span><span class="ͼg">.</span><span>textContent </span><span class="ͼg">=</span><span> </span><span class="ͼk">`</span><span>${</span><span class="ͼm">settings</span><span class="ͼg">.</span><span>address}</span><span class="ͼk"> • </span><span>${</span><span class="ͼm">settings</span><span class="ͼg">.</span><span>city}</span><span class="ͼk">`</span><span>;</span><br><br><span>  </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"heroTitle"</span><span>)</span><span class="ͼg">.</span><span>textContent </span><span class="ͼg">=</span><span> </span><span class="ͼm">settings</span><span class="ͼg">.</span><span>heroTitle;</span><br><span>  </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"heroSubtitle"</span><span>)</span><span class="ͼg">.</span><span>textContent </span><span class="ͼg">=</span><span> </span><span class="ͼm">settings</span><span class="ͼg">.</span><span>heroSubtitle;</span><br><br><span>  </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"hoursBlock"</span><span>)</span><span class="ͼg">.</span><span>innerHTML </span><span class="ͼg">=</span><span> </span><span class="ͼm">fmtHours</span><span>(</span><span class="ͼm">settings</span><span class="ͼg">.</span><span>hours);</span><br><span>  </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"contactBlock"</span><span>)</span><span class="ͼg">.</span><span>innerHTML </span><span class="ͼg">=</span><br><span>    </span><span class="ͼk">`&lt;div&gt;&lt;b&gt;Phone:&lt;/b&gt; </span><span>${</span><span class="ͼm">settings</span><span class="ͼg">.</span><span>phone}</span><span class="ͼk">&lt;/div&gt;</span><br><span class="ͼk">     &lt;div&gt;&lt;b&gt;Email:&lt;/b&gt; </span><span>${</span><span class="ͼm">settings</span><span class="ͼg">.</span><span>email}</span><span class="ͼk">&lt;/div&gt;`</span><span>;</span><br><br><span>  </span><span class="ͼg">const</span><span> </span><span class="ͼm">ul</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼm">document</span><span class="ͼg">.</span><span>getElementById(</span><span class="ͼk">"servicesList"</span><span>);</span><br><span>  </span><span class="ͼm">ul</span><span class="ͼg">.</span><span>innerHTML </span><span class="ͼg">=</span><span> </span><span class="ͼm">services</span><span class="ͼg">.</span><span>items</span><span class="ͼg">.</span><span>map(</span><span class="ͼm">x</span><span> =&gt; </span><span class="ͼk">`&lt;li&gt;</span><span>${</span><span class="ͼm">x</span><span>}</span><span class="ͼk">&lt;/li&gt;`</span><span>)</span><span class="ͼg">.</span><span>join(</span><span class="ͼk">""</span><span>);</span><br><span>})();</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
