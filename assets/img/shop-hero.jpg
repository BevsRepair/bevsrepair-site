iv id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>{</span><br><span>  "heroTitle": </span><span class="ͼk">"Professional repairs done right."</span><span>,</span><br><span>  "heroSubtitle": </span><span class="ͼk">"Collision, mechanical, glass, and refinishing — quality work and clear communication."</span><span>,</span><br><span>  "phone": </span><span class="ͼk">"204-242-2318"</span><span>,</span><br><span>  "email": </span><span class="ͼk">"bevsrepair@gmail.com"</span><span>,</span><br><span>  "address": </span><span class="ͼk">"13025 Rd 48W"</span><span>,</span><br><span>  "city": </span><span class="ͼk">"Manitou, MB R0G 1G0"</span><span>,</span><br><span>  "mapsUrl": </span><span class="ͼk">"https://www.google.com/maps?q=13025%20Rd%2048W%20Manitou%20MB"</span><br><span>  ,</span><br><span>  "hours": {</span><br><span>    "Mon": </span><span class="ͼk">"8:00–5:00"</span><span>,</span><br><span>    "Tue": </span><span class="ͼk">"8:00–5:00"</span><span>,</span><br><span>    "Wed": </span><span class="ͼk">"8:00–5:00"</span><span>,</span><br><span>    "Thu": </span><span class="ͼk">"8:00–5:00"</span><span>,</span><br><span>    "Fri": </span><span class="ͼk">"8:00–5:00"</span><span>,</span><br><span>    "Sat": </span><span class="ͼk">"Closed"</span><span>,</span><br><span>    "Sun": </span><span class="ͼk">"Closed"</span><br><span>  }</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
