<div class="no-scrollbar flex min-h-36 flex-nowrap gap-0.5 overflow-auto sm:gap-1 sm:overflow-hidden xl:min-h-44 mt-1 mb-5 [&amp;:not(:first-child)]:mt-4"><div class="border-token-border-default relative w-32 shrink-0 overflow-hidden rounded-xl border-[0.5px] md:shrink max-h-64 sm:w-[calc((100%-0.5rem)/3)] rounded-s-xl" style="aspect-ratio: 5 / 4;"><div class="group/search-image @container/search-image relative rounded-[inherit] h-full w-full" style="aspect-ratio: 5 / 4;"><button type="button" class="h-full w-full overflow-hidden rounded-[inherit]" aria-label="Open image details for AutoWorks – Black and Red Minimalist Modern Auto Repair Website by Ahmad S.  Afandi for Peterdraw Studio on Dribbble"><div style="width: 100%; height: 100%; opacity: 1; transform: none;"><img alt="https://cdn.dribbble.com/userupload/12735535/file/original-699ab6ed134665d946bb02adaf1d76ce.png?resize=752x&amp;vertical=center" referrerpolicy="no-referrer" class="bg-token-main-surface-tertiary m-0 h-full w-full object-cover" src="./shop-hero_files/original-699ab6ed134665d946bb02adaf1d76ce.png" style="object-position: 0% 50%; opacity: 1;"></div></button></div></div><div class="border-token-border-default relative w-32 shrink-0 overflow-hidden rounded-xl border-[0.5px] md:shrink max-h-64 sm:w-[calc((100%-0.5rem)/3)]" style="aspect-ratio: 5 / 4;"><div class="group/search-image @container/search-image relative rounded-[inherit] h-full w-full" style="aspect-ratio: 5 / 4;"><button type="button" class="h-full w-full overflow-hidden rounded-[inherit]" aria-label="Open image details for Browse thousands of Hero Call To Action images for design inspiration |  Dribbble"><div style="width: 100%; height: 100%; opacity: 1; transform: none;"><img alt="https://cdn.dribbble.com/userupload/45952066/file/5cfa2defc79e41218d937a4c80f2447b.png?format=webp&amp;resize=400x300&amp;vertical=center" referrerpolicy="no-referrer" class="bg-token-main-surface-tertiary m-0 h-full w-full object-cover" src="./shop-hero_file