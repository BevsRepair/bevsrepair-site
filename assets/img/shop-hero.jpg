vents-none has-data-writing-block:-mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" tabindex="-1" dir="auto" data-turn-id="cc721f6f-f1bf-4548-ad5f-b8b2552429c2" data-testid="conversation-turn-2" data-scroll-anchor="false" data-turn="assistant"><h6 class="sr-only select-none">ChatGPT said:</h6><div class="text-base my-auto mx-auto [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div tabindex="-1" class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col agent-turn"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="assistant" data-message-id="5fc66fc7-a0ec-4b1b-9b00-c87a80230a10" dir="auto" data-message-model-slug="gpt-5-2" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert w-full wrap-break-word light markdown-new-styling"><p data-start="0" data-end="80">Absolutely you can — and I love that you’re thinking about keeping costs down 👍</p>
<p data-start="82" data-end="192">Yes, you can build a website with <strong data-start="116" data-end="135">no monthly fees</strong>, but there are a couple important details to understand.</p>
<hr data-start="194" data-end="197">
<h2 data-start="199" data-end="254">✅ Option 1: Completely Free (No Monthly Cost at All)</h2>
<p data-start="256" data-end="309">You can host your site for free using platforms like:</p>
<ul data-start="311" data-end="448">
<li data-start="311" data-end="360">
<p data-start="313" data-end="360"><strong data-start="313" data-end="360"><span class="hover:entity-accent entity-underline inline cursor-pointer align-baseline"><span class="whitespace-normal">GitHub</span></span> Pages</strong></p>
</li>
<li data-start="361" data-end="404">
<p data-start="363" data-end="404"><strong data-start="363" data-end="404"><span class="hover:entity-accent entity-underline inline cursor-pointer align-baseline"><span class="whitespace-normal">Netlify</span></span></strong></p>
</li>
<li data-start="405" data-end="448">
<p data-start="407" data-end="448"><strong data-start="407" data-end="448"><span class="hover:entity-accent entity-underline inline cursor-pointer align-baseline"><span class="whitespace-normal">Vercel</span></span></strong></p>
</li>
</ul>
<p data-start="450" data-end="469">These let you host:</p>
<ul data-start="470" data-end="591">
<li data-start="470" data-end="486">
<p data-start="472" data-end="486">Basic websites</p>
</li>
<li data-start="487" data-end="511">
<p data-start="489" data-end="511">Business landing pages</p>
</li>
<li data-start="512" data-end="529">
<p data-start="514" data-end="529">Portfolio sites</p>
</li>
<li data-start="530" data-end="591">
<p data-start="532" data-end="591">Static info sites (like shop hours, services, contact form)</p>
</li>
</ul>
<p data-start="593" data-end="620"><strong data-start="593" data-end="602">Cost:</strong> $0<br data-start="605" data-end="608">
<strong data-start="608" data-end="618">Catch:</strong></p>
<ul data-start="621" data-end="766">
<li data-start="621" data-end="677">
<p data-start="623" data-end="677">You’ll use a subdomain (example: <code data-start="656" data-end="676">yourname.github.io</code>)</p>
</li>
<li data-start="678" data-end="766">
<p data-start="680" data-end="766">If you want a custom domain (<code data-start="709" data-end="724">bevsrepair.ca</code>), you’ll still pay yearly for the domain.</p>
</li>
</ul>
<hr data-start="768" data-end="771">
<h2 data-start="773" data-end="838">✅ Option 2: One-Time Payment Hosting (No Monthly Subscription)</h2>
<p data-start="840" data-end="861">Some web hosts offer:</p>
<ul data-start="862" data-end="915">
<li data-start="862" data-end="886">
<p data-start="864" data-end="886">Lifetime hosting deals</p>
</li>
<li data-start="887" data-end="915">
<p data-start="889" data-end="915">Prepaid multi-year hosting</p>
</li>
</ul>
<p data-start="917" data-end="972">You’d pay once (or every few years instead of monthly).</p>
<hr data-start="974" data-end="977">
<h2 data-start="979" data-end="1035">✅ Option 3: Self-Host (Most Control, No Monthly Fees)</h2>
<p data-start="1037" data-end="1069">If you’re comfortable with tech:</p>
<ul data-start="1071" data-end="1154">
<li data-start="1071" data-end="1096">
<p data-start="1073" data-end="1096">Run a small home server</p>
</li>
<li data-start="1097" data-end="1120">
<p data-start="1099" data-end="1120">Or use a Raspberry Pi</p>
</li>
<li data-start="1121" data-end="1154">
<p data-start="1123" data-end="1154">Or host it on your own computer</p>
</li>
</ul>
<p data-start="1156" data-end="1214"><strong data-start="1156" data-end="1165">Cost:</strong> Just electricity + domain name<br data-start="1196" data-end="1199">
<strong data-start="1199" data-end="1212">Downside:</strong></p>
<ul data-start="1215" data-end="1289">
<li data-start="1215" data-end="1228">
<p data-start="1217" data-end="1228">Needs setup</p>
</li>
<li data-start="1229" data-end="1257">
<p data-start="1231" data-end="1257">Your internet must stay on</p>
</li>
<li data-start="1258" data-end="1289">
<p data-start="1260" data-end="1289">More technical responsibility</p>
</li>
</ul>
<hr data-start="1291" data-end="1294">
<h2 data-start="1296" data-end="1342">💡 The Only Thing You Usually Still Pay For</h2>
<p data-start="1344" data-end="1395">Even if hosting is free, most people still pay for:</p>
<ul data-start="1397" data-end="1468">
<li data-start="1397" data-end="1468">
<p data-start="1399" data-end="1439"><strong data-start="1399" data-end="1414">Domain name</strong> (like <code data-start="1421" data-end="1438">yourbusiness.ca</code>)</p>
<ul data-start="1442" data-end="1468">
<li data-start="1442" data-end="1468">
<p data-start="1444" data-end="1468">Usually $15–$25 per year</p>
</li>
</ul>
</li>
</ul>
<p data-start="1470" data-end="1480">That’s it.</p>
<hr data-start="1482" data-end="1485">
<p data-start="1487" data-end="1546">Since you run <strong data-start="1501" data-end="1522">Bev’s Repair Inc.</strong>, here’s something cool:</p>
