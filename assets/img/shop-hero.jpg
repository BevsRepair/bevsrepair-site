<div class="no-scrollbar flex min-h-36 flex-nowrap gap-0.5 overflow-auto sm:gap-1 sm:overflow-hidden xl:min-h-44 mt-1 mb-5 [&amp;:not(:first-child)]:mt-4"><div class="border-token-border-default relative w-32 shrink-0 overflow-hidden rounded-xl border-[0.5px] md:shrink max-h-64 sm:w-[calc((100%-0.5rem)/3)] rounded-s-xl" style="aspect-ratio: 5 / 4;"><div class="group/search-image @container/search-image relative rounded-[inherit] h-full w-full" style="aspect-ratio: 5 / 4;"><button type="button" class="h-full w-full overflow-hidden rounded-[inherit]" aria-label="Open image details for Expert Car Body Repairs versus DIY"><div style="width: 100%; height: 100%; opacity: 1; transform: none;"><img alt="https://images.squarespace-cdn.com/content/v1/61093b2745e2f9557ddd02e6/1661946420287-YE955UGY996MM0DWRC5K/Audi%2BCar%2BBody%2BRepair%2BLiverpool" referrerpolicy="no-referrer" class="bg-token-main-surface-tertiary m-0 h-full w-full object-cover" src="./shop-hero_files/Audi+Car+Body+Repair+Liverpool" style="object-position: 50% 28.4%; opacity: 1;"></div></button></div></div><div class="border-token-border-default relative w-32 shrink-0 overflow-hidden rounded-xl border-[0.5px] md:shrink max-h-64 sm:w-[calc((100%-0.5rem)/3)]" style="aspect-ratio: 5 / 4;"><div class="group/search-image @container/search-image relative rounded-[inherit] h-full w-full" style="aspect-ratio: 5 / 4;"><button type="button" class="h-full w-full overflow-hidden rounded-[inherit]" aria-label="Open image details for View Before and After pictures for Body Shop &amp; Collision Center Customers  in Schenectady NY Area"><div style="width: 100%; height: 100%; opacity: 1; transform: none;"><img alt="https://www.goldsteincollision.com/static/dealer-15319/959694.jpg" referrerpolicy="no-referrer" class="bg-token-main-surface-tertiary m-0 h-full w-full object-cover" src="./shop-hero_files/959694.jpg" style="object-position: 9.3% 50%; opacity: 1;"></div></button></div></div><div class="border-token-border-default r